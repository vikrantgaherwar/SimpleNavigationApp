# GraphQL Server Configuration
GRAPHQL_PORT=4000
GRAPHQL_URL=http://localhost:4000/graphql

# For different environments:
# Development
# REACT_APP_GRAPHQL_URL=http://localhost:4000/graphql

# iOS Simulator
# REACT_APP_GRAPHQL_URL=http://localhost:4000/graphql

# Android Emulator
# REACT_APP_GRAPHQL_URL=http://10.0.2.2:4000/graphql

# Production
# REACT_APP_GRAPHQL_URL=https://your-production-graphql-url.com/graphql
